{
  "mcpServers": {
    "etherscan": {
      "type": "http",
      "url": "https://mcp.etherscan.io/mcp/",
      "headers": {
        "Authorization": "Bearer ${MCP_ETHERSCAN_API_KEY}"
      }
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${MCP_GITHUB_PAT}"
      }
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "${MCP_CONTEXT7_API_KEY}"
      }
    },
    "coderabbitai": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "coderabbitai-mcp@latest"
      ],
      "env": {
        "GITHUB_PAT": "${MCP_GITHUB_PAT}"
      }
    }
  }
}
